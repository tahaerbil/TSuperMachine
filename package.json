{
  "name": "tsupermachine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "WEBKIT_DISABLE_COMPOSITING_MODE=1 tauri dev",
    "tauri:dev:release": "WEBKIT_DISABLE_COMPOSITING_MODE=1 tauri dev --release",
    "tauri:build": "tauri build",
    "electron:dev": "concurrently \"npm run dev\" \"sleep 2 && electron .\"",
    "electron:build": "npm run native:build && npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --dir",
    "native:build": "npm run build --workspace=cad-addon",
    "native:rebuild": "npm run rebuild --workspace=cad-addon",
    "native:clean": "npm run clean --workspace=cad-addon",
    "test": "vitest"
  },
  "workspaces": [
    "native"
  ],
  "dependencies": {
    "@fortune-sheet/react": "^1.0.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.6",
    "@tiptap/extension-bubble-menu": "^3.14.0",
    "@tiptap/extension-code-block-lowlight": "^3.14.0",
    "@tiptap/extension-floating-menu": "^3.14.0",
    "@tiptap/extension-highlight": "^3.14.0",
    "@tiptap/extension-image": "^3.14.0",
    "@tiptap/extension-link": "^3.14.0",
    "@tiptap/extension-placeholder": "^3.14.0",
    "@tiptap/extension-table": "^3.14.0",
    "@tiptap/extension-table-cell": "^3.14.0",
    "@tiptap/extension-table-header": "^3.14.0",
    "@tiptap/extension-table-row": "^3.14.0",
    "@tiptap/extension-task-item": "^3.14.0",
    "@tiptap/extension-task-list": "^3.14.0",
    "@tiptap/extension-text-align": "^3.14.0",
    "@tiptap/extension-typography": "^3.14.0",
    "@tiptap/extension-underline": "^3.14.0",
    "@tiptap/pm": "^3.14.0",
    "@tiptap/react": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "@tiptap/suggestion": "^3.14.0",
    "@types/react-plotly.js": "^2.6.4",
    "clsx": "^2.1.1",
    "dxf-parser": "^1.1.2",
    "dxf-writer": "^1.18.4",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "jszip": "^3.10.1",
    "konva": "^10.0.12",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.554.0",
    "mathjs": "^15.1.0",
    "pdfjs-dist": "^5.4.394",
    "plotly.js-dist-min": "^3.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.3.5",
    "react-konva": "^19.2.0",
    "react-pdf": "^10.2.0",
    "react-plotly.js": "^2.6.0",
